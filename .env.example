# Alibaba Bailian / DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_TTS_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# Shared auth for custom external AI services
AI_API_KEY=
AI_API_KEY_HEADER=Authorization
AI_API_KEY_PREFIX=Bearer 

# Shared LLM fallback for chat/review/result-line
AI_LLM_BASE_URL=
AI_LLM_ENDPOINT=
AI_LLM_MODEL=qwen3.6-plus

# Optional per-route overrides
AI_CHAT_ENDPOINT=
AI_CHAT_MODEL=qwen3.6-flash-2026-04-16
AI_CHAT_API_KEY=

AI_REVIEW_ENDPOINT=
AI_REVIEW_MODEL=qwen3.6-flash-2026-04-16
AI_REVIEW_API_KEY=

AI_RESULT_LINE_ENDPOINT=
AI_RESULT_LINE_MODEL=
AI_RESULT_LINE_API_KEY=

# TTS service
AI_TTS_ENDPOINT=
AI_TTS_MODEL=qwen3-tts-flash
AI_TTS_API_KEY=

# Request timeout in milliseconds
AI_REQUEST_TIMEOUT_MS=60000
AI_REVIEW_TIMEOUT_MS=20000
