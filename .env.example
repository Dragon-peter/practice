# Xiaomi MiMo
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# Shared auth for custom external AI services
AI_API_KEY=
AI_API_KEY_HEADER=Authorization
AI_API_KEY_PREFIX=Bearer

# Shared LLM fallback for chat/review/result-line
AI_LLM_BASE_URL=https://api.xiaomimimo.com/v1
AI_LLM_ENDPOINT=
AI_LLM_MODEL=mimo-v2-flash

# Optional per-route overrides
AI_CHAT_ENDPOINT=
AI_CHAT_MODEL=mimo-v2-flash
AI_CHAT_API_KEY=

AI_REVIEW_ENDPOINT=
AI_REVIEW_MODEL=mimo-v2-flash
AI_REVIEW_API_KEY=

AI_RESULT_LINE_ENDPOINT=
AI_RESULT_LINE_MODEL=mimo-v2-flash
AI_RESULT_LINE_API_KEY=

# TTS service
AI_TTS_ENDPOINT=https://api.xiaomimimo.com/v1/chat/completions
AI_TTS_MODEL=mimo-v2.5-tts
AI_TTS_API_KEY=

# Request timeout in milliseconds
AI_REQUEST_TIMEOUT_MS=60000
AI_REVIEW_TIMEOUT_MS=20000
