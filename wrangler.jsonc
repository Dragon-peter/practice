{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "practice-honghong",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-05-05",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "MIMO_BASE_URL": "https://api.xiaomimimo.com/v1",
    "AI_LLM_BASE_URL": "https://api.xiaomimimo.com/v1",
    "AI_TTS_ENDPOINT": "https://api.xiaomimimo.com/v1/chat/completions",
    "AI_LLM_MODEL": "mimo-v2-flash",
    "AI_REVIEW_MODEL": "mimo-v2-flash",
    "AI_TTS_MODEL": "mimo-v2.5-tts",
    "AI_REVIEW_TIMEOUT_MS": "20000"
  },
  "observability": {
    "enabled": true
  }
}
